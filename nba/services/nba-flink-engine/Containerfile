# NBA Flink engine — the WHOLE NBA spine as one Apache Flink DataStream job (snapshot / rules / scoring /
# routing / lifecycle state-machine), replacing Temporal too. Reference implementation (3rd alongside the
# classic Redis spine and the Kafka Streams engine). Runs the job embedded (local MiniCluster) as one process.
FROM docker.io/library/gradle:8.7.0-jdk17 AS build
WORKDIR /app
COPY settings.gradle build.gradle ./
RUN gradle --no-daemon dependencies --configuration runtimeClasspath > /dev/null 2>&1 || true   # warm dep cache layer
COPY src ./src
RUN gradle --no-daemon test shadowJar

FROM docker.io/library/eclipse-temurin:17-jre
WORKDIR /app
COPY --from=build /app/build/libs/*-all.jar /app/app.jar
# Flink local execution wants a chunk of heap for network buffers + RocksDB-less heap state backend.
CMD ["java", "-XX:MaxRAMPercentage=70", "-jar", "/app/app.jar"]
